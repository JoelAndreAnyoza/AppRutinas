<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondoApp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/moradoIntenso"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seguimiento"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:background="@color/moradoSuave">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Día:"
            android:textColor="@color/textoPrincipal"
            android:textStyle="bold"
            android:textSize="18dp"
            android:layout_marginEnd="8dp"/>

        <Spinner
            android:id="@+id/spinnerDia"
            android:layout_width="wrap_content"
            android:layout_height="48dp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvNivel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nivel seleccionado: -"
        android:textColor="@color/textoPrincipal"
        android:padding="12dp"
        android:background="@color/white"/>

    <TextView
        android:id="@+id/tvTipoRutina"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rutina: -"
        android:textColor="@color/textoSecundario"
        android:paddingLeft="12dp"
        android:paddingBottom="12dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/containerEjercicios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        </LinearLayout>

    </ScrollView>

    <Button
        android:id="@+id/btnAgregar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Agregar ejercicio personal"
        android:backgroundTint="@color/moradoIntenso"
        android:textColor="@color/white"
        android:layout_marginTop="4dp"/>

</LinearLayout>



