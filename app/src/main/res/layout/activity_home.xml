<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fondo">

    <LinearLayout
        android:id="@+id/layoutBienvenida"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¡Bienvenido!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/textoPrincipal"
            android:gravity="center"/>
    </LinearLayout>

    <ScrollView
        android:id="@+id/layoutInicio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvFechaHoy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Jueves, 9 de Julio"
                android:textColor="@color/textoSecundario"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSaludoUsuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Hola, Usuario!"
                android:textColor="@color/textoPrincipal"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvPremiumBloqueado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⭐ Pásate a Premium para desbloquear todas las funciones"
                android:textColor="@color/principal"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:background="@android:color/white"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RUTINA DE HOY"
                    android:textColor="@color/textoSecundario"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNombreRutinaHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Entrenamiento de hoy"
                    android:textColor="@color/textoPrincipal"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/tvDetalleRutinaHoy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4 Ejercicios programados"
                    android:textColor="@color/textoSecundario"
                    android:textSize="14sp"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnIniciarEntrenamiento"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="⚡ Iniciar Entrenamiento"
                    android:textColor="@android:color/white"
                    android:backgroundTint="@color/principal"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PROGRESO DE LA SEMANA"
                    android:textColor="@color/textoSecundario"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvDiasCompletados"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nivel: Principiante"
                        android:textColor="@color/textoPrincipal"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvPorcentajeProgreso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="100%"
                        android:textColor="@color/principal"
                        android:textStyle="bold"
                        android:textSize="15sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pbProgresoSemana"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="100"
                    android:progressTint="@color/principal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detalle semanal:"
                    android:textColor="@color/textoSecundario"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvListaDiasSemana"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lunes: ⏳ En progreso...\nMartes: ⚪ Pendiente..."
                    android:textColor="@color/textoPrincipal"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/barra_navegacion"/>

</LinearLayout>